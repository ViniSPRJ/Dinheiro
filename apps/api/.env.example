# Database
DATABASE_URL="postgresql://dinheiro:dinheiro_dev_password@localhost:5433/dinheiro_dev"
REDIS_URL="redis://localhost:6379"

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# OAuth - Google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OAuth - Apple
APPLE_CLIENT_ID="com.dinheiro.app"
APPLE_TEAM_ID="your-apple-team-id"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-apple-private-key\n-----END PRIVATE KEY-----"

# Frontend URL (for CORS and redirects)
FRONTEND_URL="http://localhost:5173"

# Email - SendGrid
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
FROM_EMAIL="noreply@dinheiro.app"

# ML Service
ML_SERVICE_URL="http://localhost:8000"

# OpenSwarm Advisor Service (portfolio review & allocation optimization)
ADVISOR_SERVICE_URL="http://localhost:8001"

# External APIs (optional, for investment quotes)
COINGECKO_API_KEY=""
BRAPI_API_KEY=""

# Environment
NODE_ENV="development"
PORT="3000"
